{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/post-tool-use.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node hooks/stop.js"
      }
    ]
  }
}
